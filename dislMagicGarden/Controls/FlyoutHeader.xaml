<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Controls.FlyoutHeader"
             >
    <VerticalStackLayout BackgroundColor="{StaticResource BlossomPink}"  >
        <Label Text="Magic Garden"
               TextColor="White"
               FontSize="Large"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center" />
        <Label Text="{Binding AppVersion}" FontSize="Body" TextColor="White" />
    </VerticalStackLayout>
</ContentView>
