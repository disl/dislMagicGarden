<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="dislMagicGarden.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:dislMagicGarden"
    xmlns:views="clr-namespace:dislMagicGarden.Views"
    xmlns:res="clr-namespace:dislMagicGarden.Properties"
    xmlns:controls="clr-namespace:dislMagicGarden.Controls"       
    Shell.NavBarIsVisible="False"
    FlyoutBackgroundColor="{StaticResource CottonCandy}"
    Title="dislMagicGarden">


    <Shell.FlyoutHeader>
        <controls:FlyoutHeader />
    </Shell.FlyoutHeader>

    <ShellContent 
        Title="Start"
        ContentTemplate="{DataTemplate views:HomePage}"
        Route="HomePage" />

    <ShellContent 
        Title="{x:Static res:Resources.NewStory}"
        ContentTemplate="{DataTemplate views:FairyTalePage}"
        Route="FairyTalePage" />

    <ShellContent 
        Title="{x:Static res:Resources.NewStory}"
        ContentTemplate="{DataTemplate views:SemiAutomaticPage}"
        Route="SemiAutomaticPage" />

</Shell>
