<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:dislMagicGarden"
             xmlns:converters="clr-namespace:dislMagicGarden.Converters"
             x:Class="dislMagicGarden.App">
    <Application.Resources>
        <ResourceDictionary>

            <!--<FontFamily x:Key="OpenSansRegular">OpenSans-Regular.ttf#Open Sans</FontFamily>
            <FontFamily x:Key="OpenSansSemibold">OpenSans-Semibold.ttf#Open Sans</FontFamily>-->

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            !-- Converter -->
            <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
