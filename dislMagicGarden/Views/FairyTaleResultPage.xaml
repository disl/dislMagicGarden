<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Views.FairyTaleResultPage"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             Title="Märchen">

    <Grid BackgroundColor="{StaticResource CottonCandy}"
          Padding="20"
       
          RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Style="{StaticResource FairyInputBorderStyle}"
                StrokeShape="RoundRectangle 8"
                Padding="10">
            <Grid Background="Transparent"
              Padding="10,10,0,10"
              RowDefinitions="Auto"
              ColumnDefinitions="*,Auto" >

                <Label Grid.Column="0"
                   Text="{Binding FairyTale.Title}"
                   FontSize="20"
                   FontAttributes="Bold"
                   
                   VerticalOptions="Center" />

                <Button  Grid.Column="1"
                          FontAttributes="Bold"
                          VerticalOptions="Center"
                          HorizontalOptions="End"
                          FontSize="24"
                         Command="{Binding CloseCommand}" >
                                    <Button.ImageSource>
                                        <FontImageSource FontFamily="MaterialIcons" Glyph="&#xE5C4;" Size="24" />
                                    </Button.ImageSource>
                </Button>


                <!--<Button Grid.Column="1"
                    Text="✕"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="24"
                    Command="{Binding CloseCommand}" />-->
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="5">
            <VerticalStackLayout Spacing="14">

                <!--<Label Text="{Binding FairyTale.Story}"
                       FontSize="18"
                       TextColor="{StaticResource MidnightBlue}" />-->

                <!-- In deiner XAML Page -->
               <Label Grid.Row="1" 
       FormattedText="{Binding StoryFormatted}" 
       LineBreakMode="WordWrap" />




                <Border BackgroundColor="{StaticResource MintGarden}"
                        StrokeShape="RoundRectangle 8"
                        Padding="10">
                    <Label Text="{Binding FairyTale.Moral}"
                           FontAttributes="Italic"
                           TextColor="#2E7D32" />
                </Border>

                <CollectionView ItemsSource="{Binding FairyTale.ImageUrls}"
                                ItemsLayout="VerticalGrid,2"
                                IsVisible="{Binding FairyTale.HasImages}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="{StaticResource LavenderDream}"
                                    StrokeShape="RoundRectangle 10">
                                <Image Source="{Binding .}"
                                       Aspect="AspectFill"
                                       HeightRequest="150" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Stimme auswählen -->
                <Border Style="{StaticResource FairyInputBorderStyle}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{x:Static res:Resources.reading_voice}"  
                   FontAttributes="Bold"
                   TextColor="{StaticResource MagicBlackSoft}" />

                        <Picker Title="Stimme auswählen"
                            ItemsSource="{Binding AvailableVoices}"
                            SelectedItem="{Binding SelectedVoice}"
                                TextColor="{StaticResource MagicBlackSoft}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            FontSize="16" />
                    </VerticalStackLayout>
                </Border>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*,*,*"
                      RowDefinitions="*,*"
                      RowSpacing="10"
                      ColumnSpacing="10"
                      Margin="0,10,0,20">

                    <!-- ROW 1 -->
                    <Button Grid.Column="0"
                            Grid.Row="0"
                            Style="{StaticResource MagicButtonStyle}"
                            Command="{Binding SpeakStoryCommand}">
                            <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialIcons" Glyph="{Binding SpeakStoryGlyphIcon}" Size="24" />
                            </Button.ImageSource>
                    </Button>

                    <Button Grid.Column="1"
                            Grid.Row="0"
                            Style="{StaticResource MagicButtonStyle}"
                            Command="{Binding StopStoryCommand}">
                            <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialIcons" Glyph="&#xE047;" Size="24" />
                            </Button.ImageSource>
                    </Button>

                    <Button Grid.Column="2"
                            Grid.Row="0"
                            Style="{StaticResource MagicButtonStyle}"       
                            Command="{Binding ShareCommand}">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe80d;" Size="24" />
                            </Button.ImageSource>
                    </Button>

                    <Button Grid.Column="3"
                            Grid.Row="0"
                            Style="{StaticResource MagicButtonStyle}"
                            Command="{Binding ShowPictureCommand}">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe3f4;" Size="24" />
                            </Button.ImageSource>
                    </Button>

                    <!-- ROW 2 -->
                    <Button Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Grid.Row="1"
                            Text="{x:Static res:Resources.Quiz}"
                            Style="{StaticResource MagicButtonStyle}"
                            Command="{Binding StartQuizCommand}">      
                        <!--<Button.ImageSource>
                            <FontImageSource FontFamily="MaterialIcons" Glyph="{Binding SpeakStoryGlyphIcon}" Size="24" />
                        </Button.ImageSource>-->
                    </Button>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
