<toolkit:Popup 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:models="clr-namespace:dislMagicGarden.Models"
    xmlns:properties="clr-namespace:dislMagicGarden.Properties"
    x:Class="dislMagicGarden.Views.VoiceRecognitionPage"
    xmlns:system="clr-namespace:System;assembly=System.Runtime" xmlns:viewmodels="clr-namespace:dislMagicGarden.ViewModels" x:DataType="viewmodels:BaseViewModel"
    x:TypeArguments="system:String"
    BackgroundColor="gray">
    <VerticalStackLayout Spacing="10">
        <Label Text="{x:Static properties:Resources.Dictate_your_fairy_tale_description}"   />

        <!--<Label x:Name="statusLabel" Text="{x:Static properties:Resources.Status_Idle}" Padding="10" />-->
        <Border Stroke="{AppThemeBinding Light=#00BCD4, Dark=#80DEEA}" StrokeThickness="1" Padding="5"   >
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5" />
            </Border.StrokeShape>
            <Editor x:Name="txtResult" 
                    HeightRequest="300"    
                    IsReadOnly="True"
                    Placeholder="{x:Static properties:Resources.Your_description_appears_here}"  />
        </Border>
        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button x:Name="startButton" IsVisible="True" Text="🎤  START" FontSize="Medium" TextColor="White" Clicked="OnStartListeningClicked"   />
            <Button x:Name="stopButton" IsVisible="False" Text="⏹  STOP" FontSize="Medium" TextColor="White" Clicked="OnStopListeningClicked"  />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</toolkit:Popup>
