<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:dislMagicGarden.ViewModels"
             xmlns:models="clr-namespace:dislMagicGarden.Models"
             xmlns:converters="clr-namespace:dislMagicGarden.Converters"
             xmlns:views="clr-namespace:dislMagicGarden.Views"
             x:Class="dislMagicGarden.Views.FairyTalePage"
             Title="Märchen Generator">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

            <!-- Einheitlicher Style für Eingabecontainer -->
            <!--<Style x:Key="FairyInputBorderStyle" TargetType="Border">
                <Setter Property="Stroke" Value="{StaticResource BlossomPink}" />
                <Setter Property="StrokeThickness" Value="2" />
                <Setter Property="Background" Value="{StaticResource CottonCandy}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 15" />
                <Setter Property="Padding" Value="15" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#FFC9E3" Offset="0,4" Opacity="0.3" Radius="10" />
                    </Setter.Value>
                </Setter>
            </Style>-->
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="🎭 Märchen Generator"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Thema -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Thema deines Märchens:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MagicBlackSoft}" />
                    <Entry Text="{Binding Theme}"
                           Placeholder="z.B. 'Ein mutiges Eichhörnchen rettet den Wald'"
                          
                           FontSize="16" />
                </VerticalStackLayout>
            </Border>

            <!-- Stil -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Stil:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MagicBlackSoft}" />
                    <Picker ItemsSource="{Binding Styles}"
                            SelectedItem="{Binding SelectedStyle}"
                            Title="Stil auswählen"
                            TitleColor="Gray"
                            FontSize="16" />
                </VerticalStackLayout>
            </Border>

            <!-- Modus -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Modus:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MagicBlackSoft}" />

                    <RadioButton GroupName="Mode"
                                 Content="📝 Nur Text (DeepSeek) ~$0.0005"
                                 IsChecked="{Binding SelectedMode,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter={x:Static models:GenerationMode.TextOnly}}" />

                    <RadioButton GroupName="Mode"
                                 Content="🎨 Text + 4 Bilder (DALL·E) ~$0.16"
                                 IsChecked="{Binding SelectedMode,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter={x:Static models:GenerationMode.FullStory}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Fehler -->
            <Border IsVisible="{Binding HasError}"
                    BackgroundColor="#FFEBEE"
                    Stroke="#F44336"
                    StrokeShape="RoundRectangle 10"
                    Padding="12">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#B71C1C"
                       FontSize="14" />
            </Border>

            <!--<Label Text="{Binding StatusMessage}"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center" />-->


            <Border Style="{StaticResource FairyInputBorderStyle}"
                IsVisible="{Binding IsGenerating}"
                Margin="0,10"
                Padding="14"
                HorizontalOptions="Fill">

                <HorizontalStackLayout Spacing="12" 
                           HorizontalOptions="Center"
                           VerticalOptions="Center">

                    <ActivityIndicator 
            IsRunning="{Binding IsGenerating}"
            WidthRequest="22"
            HeightRequest="22" />

                    <Label Text="{Binding StatusMessage}"
               FontSize="18"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}" />
                </HorizontalStackLayout>
            </Border>



            <!-- Quick Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="✨ Schnell: Nur Text"
                        Command="{Binding QuickGenerateTextOnlyCommand}"
                        IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource MagicButtonStyle}" />

                <Button Grid.Column="1"
                        Text="🎨 Premium: Mit Bildern"
                        Command="{Binding PremiumGenerateWithImagesCommand}"
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="{StaticResource MintGarden}"
                        TextColor="{StaticResource MagicBlackSoft}"
                        IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>

            <!-- Hauptbutton -->
            <!--<Button Text="{Binding IsGenerating,
                                 Converter={StaticResource BoolToTextConverter},
                                 ConverterParameter='🎭 Generiere...|🎭 Märchen generieren'}"
                    Command="{Binding GenerateFairyTaleCommand}"
                    Style="{StaticResource MagicButtonStyle}"
                    BackgroundColor="{StaticResource LavenderDream}"
                    IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}" />-->

            <!-- Ergebnis -->
            <Border IsVisible="{Binding CurrentFairyTale, Converter={StaticResource NullToVisibilityConverter}}"
                    Stroke="{StaticResource FairyRose}"
     
                    StrokeShape="RoundRectangle 15"
                    Padding="0">

                <VerticalStackLayout>
                    <!-- Titel -->
                    <Grid Background="{StaticResource BlossomPink}"
                          HeightRequest="50"
                          Padding="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0"
                               Text="{Binding CurrentFairyTale.Title}"
                               TextColor="White"
                               FontSize="20"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />

                        <Button Grid.Column="1"
                                Text="✕"
                                Command="{Binding ClearResultsCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="20" />
                    </Grid>

                    <!-- Inhalt -->
                    <ScrollView Padding="15">
                        <VerticalStackLayout Spacing="15">

                            <Label Text="{Binding CurrentFairyTale.Story}"
                                   FontSize="16" />

                            <Border BackgroundColor="{StaticResource MintGarden}"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="10">
                                <Label Text="{Binding CurrentFairyTale.Moral}"
                                       FontAttributes="Italic"
                                       TextColor="#2E7D32" />
                            </Border>

                            <!-- Bilder -->
                            <CollectionView ItemsSource="{Binding CurrentFairyTale.ImageUrls}"
                                            ItemsLayout="VerticalGrid, 2"
                                            IsVisible="{Binding CurrentFairyTale.HasImages}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="{StaticResource LavenderDream}"
                                                StrokeShape="RoundRectangle 5">
                                            <Image Source="{Binding .}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="150" />
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding CurrentFairyTale.Cost}"
                                       FontSize="12"
                                       TextColor="Gray" />

                                <Button Grid.Column="1"
                                        Text="📤 Teilen"
                                        Command="{Binding ShareStoryCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource MagicBlackSoft}" />
                            </Grid>
                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</views:FairyBasePage>
