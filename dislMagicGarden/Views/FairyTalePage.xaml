<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:dislMagicGarden.ViewModels"
             xmlns:models="clr-namespace:dislMagicGarden.Models"
             xmlns:converters="clr-namespace:dislMagicGarden.Converters"
             xmlns:views="clr-namespace:dislMagicGarden.Views"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             x:Class="dislMagicGarden.Views.FairyTalePage"
             Title="Märchen Generator">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="{x:Static res:Resources.Fairy_Tale_Generator}"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Thema -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout>
                    <Label Text="{x:Static res:Resources.Theme_of_your_fairy_tale}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MagicBlackSoft}" />

                    <Grid ColumnDefinitions="*,Auto"
                       Grid.Row="6"
                       Margin="0,10,0,0"
                       ColumnSpacing="10">

                        <Entry Text="{Binding Theme}" Grid.Column="0"
                           Placeholder="{x:Static res:Resources.A_brave_squirrel_saves_the_forest}"
                           PlaceholderColor="Gray"
                           FontSize="16" />

                        <Button Text="🎤"
                            Grid.Column="1"
                            CornerRadius="10"
                            Command="{Binding AudioRecognationCommand}"
                            Style="{StaticResource MagicButtonStyle}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Märchentyp -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:Resources.fairy_tale_type}"
                       FontAttributes="Bold"
                       TextColor="{StaticResource MagicBlackSoft}" />

                    <Picker Title="{x:Static res:Resources.Select}"
                        ItemsSource="{Binding AvailableFairyTaleTypes}"
                        SelectedItem="{Binding SelectedFairyTaleType}"
                        ItemDisplayBinding="{Binding Title_description}" />
                </VerticalStackLayout>
            </Border>



            <!-- Stil -->
            <!--<Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:Resources.Style}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MagicBlackSoft}" />
                    <Picker ItemsSource="{Binding Styles}"
                            SelectedItem="{Binding SelectedStyle}"
                            Title="{x:Static res:Resources.Select_style}"
                            TitleColor="Gray"
                            FontSize="16" />
                </VerticalStackLayout>
            </Border>-->

            <!-- Sprache auswählen -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:Resources.Language}"
                        FontAttributes="Bold"
                        TextColor="{StaticResource MagicBlackSoft}" />

                    <Picker Title="{x:Static res:Resources.Select}"
                        ItemsSource="{Binding AvailableLanguages}"
                        SelectedItem="{Binding SelectedLanguage}"
                        ItemDisplayBinding="{Binding DisplayName}"                        
                        />
                </VerticalStackLayout>
            </Border>

            <!-- Modus -->
            <!--<Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:Resources.Mode}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MagicBlackSoft}" />

                    -->
            <!--Content="📝 Nur Text (DeepSeek) ~$0.0005"-->
            <!--
                    
                    <RadioButton GroupName="Mode"
                                 Content="📝 Nur Text"  
                                 IsChecked="{Binding SelectedMode,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter={x:Static models:GenerationMode.TextOnly}}" />

                    -->
            <!--<RadioButton GroupName="Mode"
                                 Content="🎨 Text + 4 Bilder (DALL·E) ~$0.16"
                                 IsChecked="{Binding SelectedMode,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter={x:Static models:GenerationMode.FullStory}}" />-->
            <!--
                </VerticalStackLayout>
            </Border>-->



            <!-- Dauer -->
            <!--<Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:Resources.Story_length}"
                              FontAttributes="Bold"
                           TextColor="{StaticResource MagicBlackSoft}" />

                    <Picker Title="{x:Static res:Resources.Select}"
                      ItemsSource="{Binding DurationOptions}"
                      SelectedItem="{Binding SelectedDuration}"
                       />
                </VerticalStackLayout>
            </Border>-->

            <!-- Fehler -->
            <Border IsVisible="{Binding HasError}"
                    BackgroundColor="#FFEBEE"
                    Stroke="#F44336"
                    StrokeShape="RoundRectangle 10"
                    Padding="12">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#B71C1C"
                       />
            </Border>

            <Border Style="{StaticResource FairyInputBorderStyle}"
                IsVisible="{Binding IsGenerating}"
                Margin="0,10"
                Padding="14"
                HorizontalOptions="Fill">

                <HorizontalStackLayout Spacing="12" 
                           HorizontalOptions="Center"
                           VerticalOptions="Center">

                    <ActivityIndicator 
                        IsRunning="{Binding IsGenerating}"
                        WidthRequest="22"
                        HeightRequest="22" />

                    <Label Text="{Binding StatusMessage}"
                 
                           TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}" />
                </HorizontalStackLayout>
            </Border>




            <!-- Quick Buttons -->
            <Grid ColumnDefinitions="*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="{x:Static res:Resources.Create_button}"
                        Command="{Binding QuickGenerateTextOnlyCommand}"
                        IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource MagicButtonStyle}" />

                <!--<Button Grid.Column="1"
                        Text="🎨 Premium: Mit Bildern"
                        Command="{Binding PremiumGenerateWithImagesCommand}"
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="{StaticResource MintGarden}"
                        TextColor="{StaticResource MagicBlackSoft}"
                        IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}" />-->
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</views:FairyBasePage>
