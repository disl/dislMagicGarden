<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Views.AdventureHistoryPage"
             xmlns:views="clr-namespace:dislMagicGarden.Views"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             Title="Abenteuerverlauf"
             BackgroundColor="{StaticResource CottonCandy}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 5"                
                StrokeThickness="0"
                HeightRequest="60">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{x:Static res:Resources.Adventure_course}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#2C3E50"
                       VerticalOptions="Center"
                       HorizontalOptions="Start"
                       Margin="20,0"/>

                <Button Grid.Column="1"
                        VerticalOptions="Center" 
                        HorizontalOptions="End" 
                        
                        Clicked="CloseButton_Clicked">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="MaterialIcons" 
                     Glyph="&#xE5C4;" 
                     Size="20" 
                      />
                    </Button.ImageSource>
                </Button>
            </Grid>
        </Border>

        <!-- Verlaufsliste -->
        <Border Grid.Row="1"
                StrokeThickness="0"
                Margin="0,5,0,5">
            <CollectionView x:Name="HistoryCollectionView"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                                Stroke="#E8F4FF"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Margin="0,0,0,7"
                                Padding="15">
                            <Grid ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto">

                                <!-- Emoji/Icon -->
                                <!--<Label Grid.Row="0"
                                       Grid.Column="0"
                                       Grid.RowSpan="2"
                                       Text="{Binding Icon}"
                                       FontSize="24"
                                       VerticalOptions="Start"
                                       HorizontalOptions="Center"
                                       Margin="0,0,10,0"/>-->

                                <!-- Schritt-Nummer -->
                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding StepNumber}"
                                       FontSize="12"
                                       TextColor="#7F8C8D"
                                       Margin="0,0,0,2"/>

                                <!-- Text -->
                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding Text}"
                                       FontSize="14"
                                       TextColor="#2C3E50"
                                       LineBreakMode="WordWrap"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>


        <!-- Buttons -->

        <Grid ColumnDefinitions="*,*,*,*" Grid.Row="2"
                  ColumnSpacing="10"
                  Margin="0,10,0,5">

            <Button Grid.Column="0"
                        Style="{StaticResource MagicButtonStyle}"
                        Clicked="SpeakStory_Clicked">
                <Button.ImageSource>
                    <FontImageSource FontFamily="MaterialIcons" Glyph="{Binding m_SpeakStory_Glyph}" Size="24" />
                </Button.ImageSource>
            </Button>

            <Button Grid.Column="1"
                        Style="{StaticResource MagicButtonStyle}"
                        Clicked="StopStory_Clicked">
                <Button.ImageSource>
                    <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe1a2;" Size="24" />
                </Button.ImageSource>
            </Button>

            <Button Grid.Column="2"
                        Style="{StaticResource MagicButtonStyle}"       
                        Clicked="Share_Clicked">
                <Button.ImageSource>
                    <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe80d;" Size="24" />
                </Button.ImageSource>
            </Button>

            <Button Grid.Column="3"
                        Style="{StaticResource MagicButtonStyle}"
                        Clicked="ShowPicture_Clicked">
                <Button.ImageSource>
                    <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe3f4;" Size="24" />
                </Button.ImageSource>
            </Button>

        </Grid>


    </Grid>
</views:FairyBasePage>