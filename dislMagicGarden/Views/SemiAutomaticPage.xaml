<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Views.SemiAutomaticPage"
             xmlns:views="clr-namespace:dislMagicGarden.Views"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             Title="Abenteuer-Welt">

    <VerticalStackLayout x:Name="ThemeSelectionArea" IsVisible="True">
        <Grid RowDefinitions="Auto, *, Auto" Padding="15">

            <!-- Header -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" 
                               Text="{x:Static res:Resources.Theme_of_your_fairy_tale}"  
                               VerticalOptions="Center"
                               TextColor="{StaticResource MagicBlackSoft}"
                               FontSize="14" />

                        <!-- History-Button -->
                        <!--<Button Grid.Column="1" 
                                VerticalOptions="Center" 
                                HorizontalOptions="End" 
                                Clicked="ShowHistory_Clicked"
                                BackgroundColor="Transparent"
                                Padding="5">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="MaterialIcons" 
                                                 Glyph="&#xE889;" 
                                                 Size="20" 
                                                 Color="#4D96FF" />
                            </Button.ImageSource>
                        </Button>-->

                        <!-- Close-Button -->
                        <Button Grid.Column="2" 
                                VerticalOptions="Center" 
                                HorizontalOptions="End" 
                                Clicked="Close_Clicked"
                                
                                >
                            <Button.ImageSource>
                                <FontImageSource FontFamily="MaterialIcons" 
                                                 Glyph="&#xE5C4;" 
                                                 Size="20" 
                                                  />
                            </Button.ImageSource>
                        </Button>
                    </Grid>

                    <Entry x:Name="ThemeEntry" 
                           Placeholder="{x:Static res:Resources.A_brave_squirrel_saves_the_forest}"
                           FontSize="14" />
                    
                    <!-- Create-Button -->
                    <Button Text="{x:Static res:Resources.Create}" 
                            Clicked="OnStartWithThemeClicked"
                            FontSize="14" >
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialIcons" 
                                 Glyph="&#xE150;" 
                                 Size="20" 
                                  />        
                        </Button.ImageSource>
                    </Button>

                    <!-- History-Button -->
                    <Button Text="{x:Static res:Resources.History}" 
                         Clicked="ShowHistory_Clicked"
                         FontSize="14" >    
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialIcons" 
                                 Glyph="&#xE889;" 
                                 Size="20" 
                                  />
                        </Button.ImageSource>
                    </Button>

                </VerticalStackLayout>
            </Border>

            <!-- Story-Bereich -->
            <Border Grid.Row="1" 
                    x:Name="StoryBorder" 
                    BackgroundColor="White" 
                    Stroke="#D1E9FF"
                    StrokeThickness="2"
                    Margin="0,8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#AACCEE" Offset="0,3" Radius="8" Opacity="0.3" />
                </Border.Shadow>

                <ScrollView Padding="15">
                    <Label x:Name="StoryLabel" 
                           TextColor="#2C3E50"
                           FontSize="14"
                           LineHeight="1.2" />
                </ScrollView>
            </Border>

            <!-- Options-Buttons -->
            <StackLayout Grid.Row="2" Spacing="8" Padding="0,8,0,0">
                <Button x:Name="Option1Btn" 
                        Text="Option 1" 
                        Style="{StaticResource MagicButtonStyle}"                   
                        BackgroundColor="#FF6B6B"
                        FontSize="13"
                        Clicked="OnOptionSelected" />

                <Button x:Name="Option2Btn" 
                        Text="Option 2" 
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="#4D96FF"
                        FontSize="13"
                        Clicked="OnOptionSelected" />

                <Button x:Name="Option3Btn" 
                        Text="Option 3"                     
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="#6BCB77"
                        FontSize="13"
                        Clicked="OnOptionSelected" />

                <ActivityIndicator x:Name="LoadingIndicator" 
                                   IsRunning="False" 
                                   IsVisible="False"
                                   Color="#4D96FF"
                                   HeightRequest="30" />
            </StackLayout>
        </Grid>
    </VerticalStackLayout>
</views:FairyBasePage>