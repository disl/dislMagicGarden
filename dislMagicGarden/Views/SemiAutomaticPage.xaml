<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Views.SemiAutomaticPage"
             xmlns:views="clr-namespace:dislMagicGarden.Views"
             xmlns:helpers="clr-namespace:dislMagicGarden.Helpers"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             Title="Abenteuer-Welt">

    <ScrollView>
        <VerticalStackLayout x:Name="ThemeSelectionArea" IsVisible="True">
            <Grid RowDefinitions="Auto, *, Auto,Auto,Auto,Auto" Padding="15" RowSpacing="5">

                <!-- Header -->
                <Border Style="{StaticResource FairyInputBorderStyle}" Grid.Row="0">
                    <VerticalStackLayout Spacing="5">
                        <Grid ColumnDefinitions="*,Auto">

                            <Label Grid.Column="0" 
                               Text="{helpers:Translate Key=Theme_of_your_fairy_tale}"  
                               VerticalOptions="Center"
                               TextColor="{StaticResource MagicBlackSoft}"
                               FontSize="14" />

                            <!-- Close-Button -->
                            <Button Grid.Column="2" 
                                VerticalOptions="Center" 
                                HorizontalOptions="End" 
                                Clicked="Close_Clicked"                                
                                >
                                <Button.ImageSource>
                                    <FontImageSource FontFamily="MaterialIcons" 
                                                 Glyph="&#xE5C4;" 
                                                 Size="20" 
                                                  />
                                </Button.ImageSource>
                            </Button>
                        </Grid>

                        <Entry x:Name="ThemeEntry" 
                           Placeholder="{helpers:Translate Key=A_brave_squirrel_saves_the_forest}"
                           FontSize="14" />

                        <!-- Zufalls-Themen -->
                        <Grid ColumnDefinitions="*,Auto" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2">

                            <Picker x:Name="ThemePicker" Grid.Column="0" 
                                 Title="{x:Static res:Resources.Select_a_random_topic}"
                                 TitleColor="Gray"
                             
                                 IsEnabled="{Binding IsNotLoadingThemes}"
                                 SelectedIndexChanged="ThemePicker_SelectedIndexChanged"
                                 TextColor="{StaticResource MagicBlackSoft}"
                        />

                            <ActivityIndicator 
                            x:Name="ThemaActivityIndicator"
                                 Grid.Column="1"                                 
                                 Color="Tomato"
                                 WidthRequest="24"
                                 HeightRequest="24"
                                 VerticalOptions="Center"
                                 HorizontalOptions="End"
                                 Margin="10,0,0,0"
                                />
                        </Grid>

                        <Button  Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2"
                              x:Name="ReloadThemesButton"
                              Text="{x:Static res:Resources.Call_up_random_topics_list}"                                                       
                              Clicked="OnReloadThemesClicked" >
                        </Button>
                    </VerticalStackLayout>
                </Border>

                <!-- Create-Button -->
                <Button Text="{helpers:Translate Key=Start}"  Grid.Row="1"
                        Clicked="OnStartWithThemeClicked">   
                    <Button.ImageSource>
                        <FontImageSource FontFamily="MaterialIcons" FontAutoScalingEnabled="True" Glyph="&#xE150;" />
                    </Button.ImageSource>
                </Button>

                <!-- History-Button -->
                <Button Text="{helpers:Translate Key=Full_story}" Grid.Row="2"
                        Clicked="ShowHistory_Clicked">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="MaterialIcons" FontAutoScalingEnabled="True" Glyph="&#xE889;" />
                    </Button.ImageSource>
                </Button>


                <!-- Story-Bereich -->
                <Border Grid.Row="3" 
                    x:Name="StoryBorder" 
                    BackgroundColor="White" 
                    Style="{StaticResource FairyInputBorderStyle}"
                    StrokeThickness="2"
                    Padding="3"
                    >
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#AACCEE" Offset="0,3" Radius="8" Opacity="0.3" />
                    </Border.Shadow>

                    <ScrollView Padding="15">
                        <Label x:Name="StoryLabel" 
                           TextColor="#2C3E50"
                           FontSize="14"
                           LineHeight="1.2" />
                    </ScrollView>
                </Border>

                <!-- Options-Buttons -->
                <StackLayout Grid.Row="4" Spacing="10" Padding="0,5,0,5">
                    <Button x:Name="Option1Btn" 
                        Text="Option 1" 
                        Style="{StaticResource MagicButtonStyle}"                   
                        BackgroundColor="#FF6B6B"
                        FontSize="13"
                        HeightRequest="-1"
                        Padding="0"        
                        VerticalOptions="Center"                        
                        Clicked="OnOptionSelected" />

                    <Button x:Name="Option2Btn" 
                        Text="Option 2" 
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="Orange"
                        FontSize="13"          
                        HeightRequest="-1"
                        Clicked="OnOptionSelected" />

                    <Button x:Name="Option3Btn" 
                        Text="Option 3"                     
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="#6BCB77"
                        FontSize="13"
                        HeightRequest="-1"
                        Clicked="OnOptionSelected" />

                    <Entry 
                    x:Name="Option4Entry"  
                    Placeholder="{helpers:Translate Key=Your_suggestion}"    
                    Completed="OnOptionSelected"
                />

                    <ActivityIndicator x:Name="LoadingIndicator" 
                                   IsRunning="False" 
                                   IsVisible="False"
                                   Color="#4D96FF"
                                   HeightRequest="30" />
                </StackLayout>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</views:FairyBasePage>