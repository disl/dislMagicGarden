<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Views.SemiAutomaticPage"
             xmlns:views="clr-namespace:dislMagicGarden.Views"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             xmlns:local="clr-namespace:dislMagicGarden.Controls"
             Title="Abenteuer-Welt"
             >

    <VerticalStackLayout x:Name="ThemeSelectionArea" IsVisible="True">
        
        <Grid RowDefinitions="Auto, *, Auto" Padding="20">

            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:Resources.Theme_of_your_fairy_tale}"  
                           TextColor="{StaticResource MagicBlackSoft}" />

                    <Entry x:Name="ThemeEntry" 
                        Placeholder="{x:Static res:Resources.A_brave_squirrel_saves_the_forest}" />
                    <Button Text="{x:Static res:Resources.Create_button}" 
                        Clicked="OnStartWithThemeClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="1" 
                x:Name="StoryBorder" 
                BackgroundColor="White" 
                Stroke="#D1E9FF"
                StrokeThickness="3"
                Margin="0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#AACCEE" Offset="0,5" Radius="10" Opacity="0.3" />
                </Border.Shadow>

                <ScrollView Padding="20">
                    <Label x:Name="StoryLabel" 
                       FontSize="20" 
                       TextColor="#2C3E50"
                       LineHeight="1.3" />
                </ScrollView>
            </Border>

            <StackLayout Grid.Row="2" Spacing="12" Padding="0,10,0,0">

                <Button x:Name="Option1Btn" 
                    Text="Option 1" 
                    Style="{StaticResource MagicButtonStyle}"                   
                    BackgroundColor="#FF6B6B"
                    Clicked="OnOptionSelected" />

                <Button x:Name="Option2Btn" 
                    Text="Option 2" 
                    Style="{StaticResource MagicButtonStyle}"
                    BackgroundColor="#4D96FF"
                    Clicked="OnOptionSelected" />

                <Button x:Name="Option3Btn" 
                    Text="Option 3"                     
                    Style="{StaticResource MagicButtonStyle}"
                    BackgroundColor="#6BCB77"
                    Clicked="OnOptionSelected" />

                <ActivityIndicator x:Name="LoadingIndicator" 
                               IsRunning="False" 
                               IsVisible="False"
                               Color="#4D96FF"
                               HeightRequest="40" />
            </StackLayout>
        </Grid>

    </VerticalStackLayout>
</views:FairyBasePage>