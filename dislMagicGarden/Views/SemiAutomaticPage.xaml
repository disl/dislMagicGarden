<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Views.SemiAutomaticPage"
             xmlns:views="clr-namespace:dislMagicGarden.Views"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             xmlns:local="clr-namespace:dislMagicGarden.Controls"
             Title="Abenteuer-Welt"
             >

    <VerticalStackLayout x:Name="ThemeSelectionArea" IsVisible="True">

        <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="20">

            <!-- Header mit History-Button -->
            <Border Style="{StaticResource FairyInputBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Label Grid.Column="0" Text="{x:Static res:Resources.Theme_of_your_fairy_tale}"  
                               VerticalOptions="Center"
                               TextColor="{StaticResource MagicBlackSoft}" />

                        <!-- History-Button -->
                        <Button Grid.Column="1" 
                                VerticalOptions="Center" 
                                HorizontalOptions="End" 
                                Clicked="ShowHistory_Clicked"
                                BackgroundColor="Transparent"
                                Padding="5">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="MaterialIcons" 
                                                 Glyph="&#xE889;" 
                                                 Size="24" 
                                                 Color="#4D96FF" />
                            </Button.ImageSource>
                            <Button.Triggers>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding Source={x:Reference HistoryPopup}, Path=IsVisible}"
                                             Value="True">
                                    <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <!-- Close-Button -->
                        <Button Grid.Column="2" 
                                VerticalOptions="Center" 
                                HorizontalOptions="End" 
                                Clicked="Close_Clicked"
                                BackgroundColor="Transparent"
                                Padding="5">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="MaterialIcons" 
                                                 Glyph="&#xE5C4;" 
                                                 Size="24" 
                                                 Color="#FF6B6B" />
                            </Button.ImageSource>
                        </Button>
                    </Grid>

                    <Entry x:Name="ThemeEntry" 
                           Placeholder="{x:Static res:Resources.A_brave_squirrel_saves_the_forest}" />
                    <Button Text="{x:Static res:Resources.Create_button}" 
                            Clicked="OnStartWithThemeClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Story-Bereich -->
            <Border Grid.Row="1" 
                    x:Name="StoryBorder" 
                    BackgroundColor="White" 
                    Stroke="#D1E9FF"
                    StrokeThickness="3"
                    Margin="0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#AACCEE" Offset="0,5" Radius="10" Opacity="0.3" />
                </Border.Shadow>

                <ScrollView Padding="20">
                    <Label x:Name="StoryLabel" 
                           TextColor="#2C3E50"
                           LineHeight="1.3" />
                </ScrollView>
            </Border>

            <!-- Options-Buttons -->
            <StackLayout Grid.Row="2" Spacing="12" Padding="0,10,0,0">
                <Button x:Name="Option1Btn" 
                        Text="Option 1" 
                        Style="{StaticResource MagicButtonStyle}"                   
                        BackgroundColor="#FF6B6B"
                        Clicked="OnOptionSelected" />

                <Button x:Name="Option2Btn" 
                        Text="Option 2" 
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="#4D96FF"
                        Clicked="OnOptionSelected" />

                <Button x:Name="Option3Btn" 
                        Text="Option 3"                     
                        Style="{StaticResource MagicButtonStyle}"
                        BackgroundColor="#6BCB77"
                        Clicked="OnOptionSelected" />

                <ActivityIndicator x:Name="LoadingIndicator" 
                                   IsRunning="False" 
                                   IsVisible="False"
                                   Color="#4D96FF"
                                   HeightRequest="40" />
            </StackLayout>

            <!-- History Popup (versteckt standardmäßig) -->
            <Frame Grid.Row="3"
                   x:Name="HistoryPopup"
                   IsVisible="False"
                   BackgroundColor="White"
                   BorderColor="#D1E9FF"
                   CornerRadius="15"
                   Padding="15"
                   Margin="0,10,0,0"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" 
                               Text="Abenteuer-Verlauf" 
                               FontAttributes="Bold" 
                               FontSize="18"
                               TextColor="#2C3E50" />

                        <Button Grid.Column="1"
                                Text="✕"
                                FontSize="16"
                                TextColor="#FF6B6B"
                                BackgroundColor="Transparent"
                                Clicked="HideHistory_Clicked" />
                    </Grid>

                    <CollectionView x:Name="HistoryCollectionView"
                                    ItemsSource="{Binding StoryHistoryDisplay}"
                                    VerticalOptions="Start"
                                    HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10,5"
                                      ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0"
                                           Text="•"
                                           TextColor="#4D96FF"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding .}"
                                           TextColor="#2C3E50"
                                           VerticalOptions="Center"
                                           LineBreakMode="WordWrap" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="Verlauf löschen"
                            BackgroundColor="#FFE0E0"
                            TextColor="#FF6B6B"
                            Clicked="ClearHistory_Clicked" />
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </VerticalStackLayout>
</views:FairyBasePage>



