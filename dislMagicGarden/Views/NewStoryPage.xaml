<?xml version="1.0" encoding="utf-8" ?>
<views:FairyBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dislMagicGarden.Views.NewStoryPage"
             xmlns:res="clr-namespace:dislMagicGarden.Properties"
             xmlns:views="clr-namespace:dislMagicGarden.Views">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Entry Placeholder="Name des Kindes"
                   Text="{Binding ChildName}" />

            <Entry Placeholder="Tierfreund"
                   Text="{Binding SidekickAnimal}" />

            <Entry Placeholder="Zauberwelt (z.B. Wald, Meer)"
                   Text="{Binding WorldSetting}" />

            <Picker 
                Title="Stimmung" 
                ItemsSource="{Binding Moods}"
                SelectedItem="{Binding Mood}">
               
            </Picker>

            <Button Text="Geschichte zaubern ✨"
                    Command="{Binding GenerateStoryCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</views:FairyBasePage>