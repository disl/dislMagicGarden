<?xml version="1.0" encoding="utf-8"?>
<ContentPage 
    x:Class="dislMagicGarden.Views.ChapterEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:dislMagicGarden.ViewModels"
    xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls">

    <ContentPage.BindingContext>
        <vm:ChapterEditorViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource CottonCandy}">

        <!-- 🎨 Zeichenbereich -->
        <skia:SKCanvasView 
            x:Name="CanvasView"
            Grid.Row="0"
            PaintSurface="OnPaintSurface"
            EnableTouchEvents="True"
            Touch="OnCanvasTouch" />

        <!-- 🧒 UI-Leiste für Kinder -->
        <HorizontalStackLayout 
            Grid.Row="1"
            Padding="16"
            Spacing="20"
            BackgroundColor="{StaticResource FairyRose}">

            <Button 
                Text="🎨 Farbe"
                Command="{Binding ChangeColorCommand}"
                BackgroundColor="{StaticResource MagicPink}" />

            <Button 
                Text="↩️ Undo"
                Command="{Binding UndoCommand}"
                BackgroundColor="{StaticResource BlossomPink}" />

            <Button 
                Text="💾 Speichern"
                Command="{Binding SaveCommand}"
                BackgroundColor="{StaticResource SoftGold}"
                TextColor="Black" />

        </HorizontalStackLayout>

    </Grid>

</ContentPage>
